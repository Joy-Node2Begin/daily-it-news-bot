{
    "name":  "1E - Twitter/X Notification",
    "nodes":  [
                  {
                      "parameters":  {
                                         "content":  "## 1E — Twitter/X Notification\n\n**Schedule:** Daily 15:00 IST\n**Method:** Sends tweet text via Telegram + Email for manual posting\n\n**Prerequisites:**\n1. Workflow 1A must have saved payload\n2. n8n variables: `CRM_API_URL`, `CRM_API_KEY`, `TELEGRAM_BOT_TOKEN`, `TELEGRAM_CHAT_ID`",
                                         "height":  180,
                                         "width":  620,
                                         "color":  3
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000001",
                      "name":  "📋 Setup Instructions",
                      "type":  "n8n-nodes-base.stickyNote",
                      "typeVersion":  1,
                      "position":  [
                                       -60,
                                       -20
                                   ]
                  },
                  {
                      "parameters":  {
                                         "rule":  {
                                                      "interval":  [
                                                                       {
                                                                           "field":  "cronExpression",
                                                                           "expression":  "0 15 * * *"
                                                                       }
                                                                   ]
                                                  }
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000010",
                      "name":  "Daily 15:00 IST",
                      "type":  "n8n-nodes-base.scheduleTrigger",
                      "typeVersion":  1.2,
                      "position":  [
                                       100,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "GET",
                                         "url":  "={{ $env.CRM_API_URL + \u0027/api/content?date=\u0027 + $now.toFormat(\u0027yyyy-MM-dd\u0027) + \u0027\u0026with_payload=1\u0027 }}",
                                         "authentication":  "genericCredentialType",
                                         "genericAuthType":  "httpHeaderAuth",
                                         "options":  {

                                                     }
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000020",
                      "name":  "Load Today\u0027s Payload",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       400,
                                       400
                                   ],
                      "credentials":  {
                                          "httpHeaderAuth":  {
                                                                 "id":  "CHANGE_ME_CRM",
                                                                 "name":  "CRM API Auth"
                                                             }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const response = $input.first().json;\nconst data = response.data;\n\nif (!data || (Array.isArray(data) \u0026\u0026 data.length === 0)) {\n  return [{ json: { _hasPayload: false } }];\n}\n\nconst row = Array.isArray(data) ? data[0] : data;\nlet payload = {};\nif (row.prepared_payload) {\n  try { payload = JSON.parse(row.prepared_payload); } catch(e) {}\n}\n\nif (!row.twitter_caption \u0026\u0026 !payload.twitter_caption) {\n  return [{ json: { _hasPayload: false } }];\n}\n\nreturn [{ json: { ...row, ...payload, _hasPayload: true } }];"
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000025",
                      "name":  "Validate Payload",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       700,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "boolean":  [
                                                                            {
                                                                                "value1":  "={{ $json._hasPayload }}"
                                                                            }
                                                                        ],
                                                            "combinator":  "and",
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict",
                                                                            "version":  1
                                                                        }
                                                        },
                                         "options":  {

                                                     }
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000030",
                      "name":  "Has Payload?",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2,
                      "position":  [
                                       980,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027 }}",
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ { chat_id: $env.TELEGRAM_CHAT_ID, text: \u0027⚠️ Twitter/X: No payload for today (\u0027 + $now.toFormat(\u0027yyyy-MM-dd\u0027) + \u0027)\u0027 } }}",
                                         "options":  {

                                                     }
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000035",
                      "name":  "Alert: No Payload",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1260,
                                       620
                                   ]
                  },
                  {
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "={{ \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027 }}",
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ { chat_id: $env.TELEGRAM_CHAT_ID, text: \u0027🐦 Twitter/X Post Ready — Please post manually:\\n\\n--- TWEET (copy below, max 280 chars) ---\\n\u0027 + $json.twitter_caption + \u0027\\n\\nImage: \u0027 + ($json.direct_image_url || $json.image_url || \u0027\u0027) + \u0027\\n\\nAfter posting, reply with the tweet URL.\u0027 } }}",
                                         "options":  {

                                                     }
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000040",
                      "name":  "Telegram: Tweet Text",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1260,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const item = $(\u0027Validate Payload\u0027).first().json;\nconst CRM = $env.CRM_API_URL;\nconst API_KEY = $env.CRM_API_KEY;\nconst headers = { \u0027Authorization\u0027: \u0027Bearer \u0027 + API_KEY, \u0027Content-Type\u0027: \u0027application/json\u0027 };\n\n// Log to posting\nawait this.helpers.httpRequest({\n  method: \u0027POST\u0027,\n  url: CRM + \u0027/api/posting\u0027,\n  body: {\n    content_calendar_id: item.id,\n    platform: \u0027twitter\u0027,\n    status: \u0027notification_sent\u0027,\n    date: $now.toFormat(\u0027yyyy-MM-dd\u0027),\n    brand: item.brand,\n    content_type: item.content_type,\n    content_item: item.topic || \u0027\u0027,\n    area: item.area_id\n  },\n  headers: headers,\n  json: true\n});\n\nreturn [{ json: { platform: \u0027twitter\u0027, status: \u0027notification_sent\u0027 } }];"
                                     },
                      "id":  "1e000000-0001-4000-8000-000000000050",
                      "name":  "Log Twitter Posting",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1540,
                                       400
                                   ]
                  }
              ],
