                      "id":  "1a000000-0001-4000-8000-000000000040",
                      "name":  "Check Duplicate Combo",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       1260,
                                       400
                                   ],
                      "credentials":  {
                                          "httpHeaderAuth":  {
                                                                 "id":  "CHANGE_ME_CRM",
                                                                 "name":  "CRM API Auth"
                                                             }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const comboResponse = $input.first().json;\nconst content = $(\u0027Check Content Exists\u0027).first().json;\n\n// Check if combo was used within 60 days\nconst comboData = comboResponse.data;\nlet isBlocked = false;\n\nif (comboData \u0026\u0026 comboData.last_used_date) {\n  const lastUsed = new Date(comboData.last_used_date);\n  const now = new Date();\n  const daysSinceUsed = Math.floor((now - lastUsed) / (1000 * 60 * 60 * 24));\n  isBlocked = daysSinceUsed \u003c 60;\n}\n\nreturn [{ json: { ...content, _isBlocked: isBlocked, _comboData: comboData || {} } }];"
                                     },
                      "id":  "1a000000-0001-4000-8000-000000000045",
                      "name":  "Evaluate Combo",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1540,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "boolean":  [
                                                                            {
                                                                                "value1":  "={{ $json._isBlocked }}"
                                                                            }
                                                                        ],
                                                            "combinator":  "and",
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict",
                                                                            "version":  1
                                                                        }
