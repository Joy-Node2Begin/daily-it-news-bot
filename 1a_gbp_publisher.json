                      "id":  "1a000000-0001-4000-8000-000000000020",
                      "name":  "Fetch Today\u0027s Content",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       400,
                                       400
                                   ],
                      "credentials":  {
