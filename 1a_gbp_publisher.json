                  },
                  {
                      "parameters":  {
                                         "method":  "GET",
                                         "url":  "={{ $env.CRM_API_URL + \u0027/api/combo/check?brand=\u0027 + $json.brand + \u0027\u0026content_type=\u0027 + $json.content_type + \u0027\u0026content_item_id=\u0027 + $json.content_item_id + \u0027\u0026area_id=\u0027 + $json.area_id }}",
                                         "authentication":  "genericCredentialType",
                                         "genericAuthType":  "httpHeaderAuth",
