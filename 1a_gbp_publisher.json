                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ { chat_id: $env.TELEGRAM_CHAT_ID, text: \u0027⚠️ No approved content for today (\u0027 + $now.toFormat(\u0027yyyy-MM-dd\u0027) + \u0027). Please check the Content Calendar.\u0027, parse_mode: \u0027HTML\u0027 } }}",
