                                                                            }
                                                                        ],
                                                            "combinator":  "and",
                                                            "options":  {
                                                                            "caseSensitive":  true,
                                                                            "leftValue":  "",
                                                                            "typeValidation":  "strict",
                                                                            "version":  1
                                                                        }
                                                        },
                                         "options":  {

                                                     }
                                     },
                      "id":  "1d000000-0001-4000-8000-000000000050",
                      "name":  "Pin Created?",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  2,
                      "position":  [
                                       1560,
                                       400
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const item = $input.first().json;\nconst CRM = $env.CRM_API_URL;\nconst API_KEY = $env.CRM_API_KEY;\nconst headers = { \u0027Authorization\u0027: \u0027Bearer \u0027 + API_KEY, \u0027Content-Type\u0027: \u0027application/json\u0027 };\n\nawait this.helpers.httpRequest({\n  method: \u0027POST\u0027,\n  url: CRM + \u0027/api/posting\u0027,\n  body: {\n    content_calendar_id: item.id,\n    platform: \u0027pinterest\u0027,\n    status: \u0027success\u0027,\n    post_url: item.pin_id,\n    date: $now.toFormat(\u0027yyyy-MM-dd\u0027),\n    brand: item.brand,\n    content_type: item.content_type,\n    content_item: item.topic || \u0027\u0027,\n    area: item.area_id\n  },\n  headers: headers,\n  json: true\n});\n\nreturn [{ json: { platform: \u0027pinterest\u0027, status: \u0027success\u0027, pin_id: item.pin_id } }];"
                                     },
                      "id":  "1d000000-0001-4000-8000-000000000060",
                      "name":  "Log Pin Success",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1860,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const item = $input.first().json;\nconst CRM = $env.CRM_API_URL;\nconst API_KEY = $env.CRM_API_KEY;\nconst headers = { \u0027Authorization\u0027: \u0027Bearer \u0027 + API_KEY, \u0027Content-Type\u0027: \u0027application/json\u0027 };\n\nawait this.helpers.httpRequest({\n  method: \u0027POST\u0027,\n  url: CRM + \u0027/api/posting\u0027,\n  body: {\n    content_calendar_id: item.id,\n    platform: \u0027pinterest\u0027,\n    status: \u0027failed\u0027,\n    error: item.pin_error || \u0027Failed after 3 attempts\u0027,\n    date: $now.toFormat(\u0027yyyy-MM-dd\u0027),\n    brand: item.brand,\n    content_type: item.content_type,\n    content_item: item.topic || \u0027\u0027,\n    area: item.area_id\n  },\n  headers: headers,\n  json: true\n});\n\n// Telegram alert\nawait this.helpers.httpRequest({\n  method: \u0027POST\u0027,\n  url: \u0027https://api.telegram.org/bot\u0027 + $env.TELEGRAM_BOT_TOKEN + \u0027/sendMessage\u0027,\n  body: {\n    chat_id: $env.TELEGRAM_CHAT_ID,\n    text: \u0027❌ Pinterest posting failed after 3 attempts — \u0027 + $now.toFormat(\u0027yyyy-MM-dd\u0027) + \u0027\\nError: \u0027 + (item.pin_error || \u0027Unknown\u0027)\n  },\n  json: true\n});\n\nreturn [{ json: { platform: \u0027pinterest\u0027, status: \u0027failed\u0027 } }];"
                                     },
