      "id": "8"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\nfor (const item of $input.all()) {\n  const title = item.json.title || 'Tech News';\n  const link = item.json.url || item.json.link || item.json.id;\n  const snippet = item.json.contentSnippet || item.json.description || item.json.content || '';\n  let cleanSnippet = snippet.replace(/<[^>]*>?/gm, '').substring(0, 150);\n  if (cleanSnippet.length === 150) cleanSnippet += '...';\n  \n  const final_text = `\ud83d\ude80 *${title}*\\n\\n${cleanSnippet}\\n\\n\ud83d\udd17 [Read More](${link})`;\n  \n  results.push({\n    json: {\n      final_text: final_text,\n      title: title,\n      url: link\n    }\n  });\n}\nreturn results;"
      },
