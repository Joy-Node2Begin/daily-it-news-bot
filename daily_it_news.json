        }
      }
    },
    {
      "parameters": {
        "jsCode": "const postedUrls = $('Read Posted URLs').all()\n  .map(i => i.json.URL)\n  .filter(Boolean);\n\nconst seen = new Set();\n\nreturn $('Flatten Items').all().filter(item => {\n  const url = item.json.url || item.json.link;\n  if (postedUrls.includes(url)) return false;\n  if (seen.has(url)) return false;\n  seen.add(url);\n  return true;\n});"
      },
      "name": "Remove Duplicates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3000,
