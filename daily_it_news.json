    {
      "parameters": {
        "jsCode": "const allArticles = [];\n\nfor (const item of $input.all()) {\n  if (item.json.articles && Array.isArray(item.json.articles)) {\n    for (const article of item.json.articles) {\n      allArticles.push({ json: article });\n    }\n  } else {\n    allArticles.push(item);\n  }\n}\n\nreturn allArticles.filter(item => item.json.title);"
      },
